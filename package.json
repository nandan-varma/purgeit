{
  "name": "purgeit",
  "version": "0.1.1",
  "description": "Interactive, safe, configurable CLI to find and delete regenerable dev build artifacts (node_modules, dist, target, Pods, ...) across your projects",
  "license": "MIT",
  "author": "Nandan Varma",
  "homepage": "https://purgeit.nandan.fyi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nandan-varma/purgeit.git"
  },
  "bugs": {
    "url": "https://github.com/nandan-varma/purgeit/issues"
  },
  "keywords": [
    "cli",
    "node_modules",
    "cleanup",
    "disk-space",
    "disk-cleanup",
    "npkill",
    "dev-tools",
    "monorepo",
    "build-artifacts",
    "artifact-cleaner",
    "storage",
    "tui",
    "terminal-ui",
    "interactive-cli",
    "target",
    "pods",
    "cocoapods",
    "gradle",
    "cargo",
    "rust",
    "xcode"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "purgeit": "dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.2",
    "ink": "^7.1.1",
    "p-limit": "^7.3.1",
    "react": "^19.2.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.10",
    "cosmiconfig-typescript-loader": "^6.3.0",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "cosmiconfig-typescript-loader": ">=6.0.0",
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "cosmiconfig-typescript-loader": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
