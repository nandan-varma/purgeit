{
  "name": "purgeit",
  "version": "0.0.4",
  "description": "Interactive, safe, configurable CLI to find and delete regenerable dev build artifacts (node_modules, dist, target, Pods, ...) across your projects",
  "license": "MIT",
  "author": "Nandan Varma",
  "homepage": "https://github.com/nandan-varma/purgeit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nandan-varma/purgeit.git"
  },
  "bugs": {
    "url": "https://github.com/nandan-varma/purgeit/issues"
  },
  "keywords": [
    "cli",
    "node_modules",
    "cleanup",
    "disk-space",
    "npkill",
    "dev-tools",
    "monorepo",
    "build-artifacts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "purgeit": "dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.2",
    "cosmiconfig-typescript-loader": "^6.3.0",
    "ink": "^6.8.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.7",
    "react-devtools-core": "^6.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.7",
    "@vitest/coverage-v8": "^3.2.6",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
